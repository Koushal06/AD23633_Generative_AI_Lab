(import re) Tj
T* (import pandas as pd) Tj
T* (import matplotlib.pyplot as plt) Tj
T* (from datasets import load_dataset) Tj
T* (from transformers import pipeline) Tj
T* () Tj
T* (# Load dataset) Tj
T* (dataset = load_dataset\("gsm8k", "main"\)) Tj
T* (samples = dataset["test"].select\(range\(5\)\)) Tj
T* () Tj
T* (print\("Number of questions selected:", len\(samples\)\)) Tj
T* (print\("\\nFirst sample:\\n", samples[0]\)) Tj
T* () Tj
T* (# Load model) Tj
T* (generator = pipeline\() Tj
T* (    "text-generation",) Tj
T* (    model="TinyLlama/TinyLlama-1.1B-Chat-v1.0",) Tj
T* (    device_map="auto") Tj
T* (\)) Tj
T* () Tj
T* (print\("Model loaded successfully."\)) Tj
T* () Tj
T* (# Prompt templates) Tj
T* (def zero_shot_prompt\(question\):) Tj
T* (    return f"""Solve the following math problem.) Tj
T* (Give only the final answer.) Tj
T* () Tj
T* (Question: {question}) Tj
T* (Answer:""") Tj
T* () Tj
T* (def few_shot_prompt\(question\):) Tj
T* (    return f"""Solve the following math problems.) Tj
T* () Tj
T* (Example 1:) Tj
T* (Question: Ravi has 3 apples and buys 2 more. How many apples does he have?) Tj
T* (Answer: 5) Tj
T* () Tj
T* (Example 2:) Tj
T* (Question: There are 4 pencils in one box. If there are 3 boxes, how many pencils are there?) Tj
T* (Answer: 12) Tj
T* () Tj
T* (Now solve:) Tj
T* (Question: {question}) Tj
T* (Answer:""") Tj
T* () Tj
T* (def cot_prompt\(question\):) Tj
T* (    return f"""Solve the following math problem step by step.) Tj
T* (Then give the final answer clearly.) Tj
T* () Tj
T* (Question: {question}) Tj
T* (Solution:""") Tj
T* () Tj
T* (# Generate response) Tj
T* (def get_response\(prompt\):) Tj
T* (    output = generator\() Tj
T* (        prompt,) Tj
T* (        max_new_tokens=128,) Tj
T* (        do_sample=False,   # deterministic) Tj
T* (        pad_token_id=generator.tokenizer.eos_token_id,) Tj
T* (        return_full_text=False  # FIX: cleaner output) Tj
T* (    \)) Tj
T* (    return output[0]["generated_text"].strip\(\)) Tj
T* () Tj
T* (# Extract number) Tj
T* (def extract_number\(text\):) Tj
T* (    if text is None:) Tj
T* (        return None) Tj
T* (    numbers = re.findall\(r'-?\\d+\\.?\\d*', text.replace\(",", ""\)\)) Tj
T* (    return numbers[-1] if numbers else None) Tj
T* () Tj
T* (# Run experiment) Tj
T* (results = []) Tj
T* () Tj
T* (for i, sample in enumerate\(samples\):) Tj
T* (    question = sample["question"]) Tj
T* (    true_answer_text = sample["answer"]) Tj
T* (    true_answer = extract_number\(true_answer_text\)) Tj
T* () Tj
T* (    for prompt_type, prompt_func in [) Tj
T* (        \("Zero-shot", zero_shot_prompt\),) Tj
T* (        \("Few-shot", few_shot_prompt\),) Tj
T* (        \("Chain-of-Thought", cot_prompt\)) Tj
T* (    ]:) Tj
T* (        prompt = prompt_func\(question\)) Tj
T* (        response = get_response\(prompt\)) Tj
T* (        pred = extract_number\(response\)) Tj
T* () Tj
T* (        results.append\({) Tj
T* (            "id": i,) Tj
T* (            "question": question,) Tj
T* (            "prompt_type": prompt_type,) Tj
T* (            "model_response": response,) Tj
T* (            "true_answer": true_answer,) Tj
T* (            "predicted_answer": pred) Tj
T* (        }\)) Tj
T* () Tj
T* (print\("Experiment completed."\)) Tj
T* () Tj
T* (# DataFrame) Tj
T* (df = pd.DataFrame\(results\)) Tj
T* () Tj
T* (# Convert to numeric for accurate comparison) Tj
T* (df["true_answer"] = pd.to_numeric\(df["true_answer"], errors="coerce"\)) Tj
T* (df["predicted_answer"] = pd.to_numeric\(df["predicted_answer"], errors="coerce"\)) Tj
T* () Tj
T* (# Accuracy check) Tj
T* (df["is_correct"] = df["true_answer"] == df["predicted_answer"]) Tj
T* () Tj
T* (print\(df[["id", "prompt_type", "true_answer", "predicted_answer", "is_correct"]]\)) Tj
T* () Tj
T* (# Accuracy table) Tj
T* (accuracy_table = df.groupby\("prompt_type"\)["is_correct"].mean\(\) * 100) Tj
T* (accuracy_table = accuracy_table.reset_index\(\)) Tj
T* (accuracy_table.columns = ["Prompt Type", "Accuracy \(%\)"]) Tj
T* () Tj
T* (print\("\\nAccuracy Table:\\n", accuracy_table\)) Tj
T* () Tj
T* (# Plot) Tj
T* (plt.figure\(figsize=\(8, 5\)\)) Tj
T* (plt.bar\(accuracy_table["Prompt Type"], accuracy_table["Accuracy \(%\)"]\)) Tj
T* (plt.xlabel\("Prompt Type"\)) Tj
T* (plt.ylabel\("Accuracy \(%\)"\)) Tj
T* (plt.title\("Accuracy Comparison of Prompting Techniques"\)) Tj
T* (plt.show\(\)) Tj
ET
endstream
endobj
